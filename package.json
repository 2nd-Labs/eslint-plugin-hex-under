{
  "author": "0xflotus",
  "description": "This ESLint rule proves that hex numbers are less than a specified value.",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/eslint-plugin": "1.6.14",
    "bats": "1.13.0",
    "eslint": "10.1.0",
    "eslint-plugin-eslint-plugin": "7.3.2",
    "eslint-vitest-rule-tester": "3.1.0",
    "prettier": "3.8.1",
    "tinyexec": "1.0.4",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "binary",
    "eslint",
    "eslint-plugin",
    "hex",
    "hexadecimal",
    "lint",
    "octal",
    "static-analysis"
  ],
  "license": "MIT",
  "main": "src/eslint-plugin-hex-under.js",
  "name": "eslint-plugin-hex-under",
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "repository": "github:0xflotus/eslint-plugin-hex-under",
  "scripts": {
    "coverage": "vitest run --coverage",
    "format": "prettier . --check",
    "lint": "eslint src --config eslint.config.js",
    "prelint": "npm run format",
    "test": "vitest run",
    "test:all": "npm run test && npm run test:bats",
    "test:bats": "bats --print-output-on-failure --abort --verbose-run test/bats/*.bats",
    "test:watch": "vitest"
  },
  "type": "module",
  "version": "1.7.16"
}
